---
import BaseLayout from './BaseLayout.astro';
import Prose from '../components/Prose.astro';
import ChapterNav from '../components/ChapterNav.astro';
import Icon from '../components/Icon.astro';
import { withBase } from '../lib/site';
import { volumeName, type Chapter } from '../lib/content';

interface Props {
  chapter: Chapter;
  html: string;
  prev: Chapter | null;
  next: Chapter | null;
  position: number;
  total: number;
}
const { chapter, html, prev, next, position, total } = Astro.props;
const description = chapter.dateline
  ? `${chapter.title} — ${chapter.dateline}`
  : `${chapter.title} of Hollow Reign, a queer space saga.`;
const isInterlude = chapter.interlude === true;
---
<BaseLayout title={chapter.title} description={description} type="article">
  <div class="reader-progress" aria-hidden="true"></div>

  <div class="reader-toolbar">
    <div class="container reader-toolbar__inner">
      <a class="crumb" href={withBase('/table-of-contents/')}>
        <Icon name="list" size={18} /> Contents
      </a>
      <span class="spacer"></span>
      <span class="reader-count" aria-hidden="true">{position} / {total}</span>
      <div class="reader-settings">
        <button
          class="icon-btn"
          type="button"
          aria-expanded="false"
          aria-controls="reader-settings-panel"
          aria-label="Reading settings"
          data-settings-toggle
        >
          <Icon name="sliders" size={18} />
        </button>
        <div class="reader-settings__panel" id="reader-settings-panel" role="group" aria-label="Reading settings" hidden>
          <div class="reader-settings__row">
            <span id="rs-theme">Theme</span>
            <div class="segmented" role="group" aria-labelledby="rs-theme">
              <button type="button" data-theme-pref="light" aria-pressed="false">Light</button>
              <button type="button" data-theme-pref="dark" aria-pressed="false">Dark</button>
              <button type="button" data-theme-pref="system" aria-pressed="false">System</button>
            </div>
          </div>
          <div class="reader-settings__row">
            <span id="rs-size">Text size</span>
            <div class="segmented" role="group" aria-labelledby="rs-size">
              <button type="button" data-scale="0.9" aria-pressed="false" aria-label="Smaller text" style="font-size:0.85rem">A</button>
              <button type="button" data-scale="1" aria-pressed="false" aria-label="Default text size">A</button>
              <button type="button" data-scale="1.15" aria-pressed="false" aria-label="Larger text" style="font-size:1.25rem">A</button>
            </div>
          </div>
          <p class="reader-settings__hint">Tip: use ← and → to turn the page.</p>
        </div>
      </div>
    </div>
  </div>

  <article
    class:list={['chapter', 'container', isInterlude && 'is-interlude']}
    data-chapter-slug={chapter.slug}
    data-chapter-number={String(chapter.number)}
    data-chapter-title={chapter.title}
  >
    <header class="chapter-header">
      <p class="chapter-num">{isInterlude ? 'Interlude' : `Volume ${volumeName(chapter.volume)}`}</p>
      <h1>{chapter.title}</h1>
    </header>
    <Prose html={html} />
    <ChapterNav prev={prev} next={next} />
  </article>

  <script>
    import '../scripts/reader.ts';
  </script>
</BaseLayout>
