---
import PageLayout from '../layouts/PageLayout.astro';
import Prose from '../components/Prose.astro';
import { getPageHtml, getPageMeta } from '../lib/content';
const slug = 'about-the-project';
const meta = getPageMeta(slug);
---
<PageLayout title={meta?.title ?? 'About the Project'} eyebrow="Hollow Reign">
  <Prose html={getPageHtml(slug)} />
</PageLayout>
