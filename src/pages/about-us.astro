---
import PageLayout from '../layouts/PageLayout.astro';
import Prose from '../components/Prose.astro';
import { getPageHtml, getPageMeta } from '../lib/content';
const slug = 'about-us';
const meta = getPageMeta(slug);
---
<PageLayout title={meta?.title ?? 'About the Creator'} eyebrow="The Writer">
  <Prose html={getPageHtml(slug)} />
</PageLayout>
