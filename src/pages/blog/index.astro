---
import PageLayout from '../../layouts/PageLayout.astro';
import { POSTS } from '../../lib/content';
import { withBase } from '../../lib/site';
---
<PageLayout
  title="Blog"
  eyebrow="News & Essays"
  lede="Release notes, behind-the-scenes thoughts, and essays from the creators."
>
  <div class="post-list">
    {
      POSTS.map((p) => (
        <a class="card post-card" href={withBase(`/blog/${p.slug}/`)}>
          <p class="meta"><time datetime={p.date}>{p.dateDisplay}</time></p>
          <h3>{p.title}</h3>
          <p>{p.excerpt}</p>
        </a>
      ))
    }
  </div>
</PageLayout>
